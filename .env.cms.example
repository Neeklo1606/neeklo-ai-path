# Copy into project root .env (do not commit secrets).

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# JWT for CMS API (min 32 characters in production)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# CMS Node server
CMS_SERVER_PORT=8787

# Optional: OpenAI if assistants have no provider_api_key in DB
OPENAI_API_KEY=

# Local AI (Ollama on GPU or LAN) — chat + embeddings
OLLAMA_URL=http://188.124.55.89:11434

# Qdrant (API server; default local)
QDRANT_URL=http://127.0.0.1:6333
# QDRANT_API_KEY=

# Billing (POST /chat): balance, usage logs, rate limit per site key hash
BILLING_INITIAL_BALANCE=100
BILLING_COST_PER_MESSAGE=0
BILLING_COST_PER_1K_TOKENS=0.001
BILLING_RATE_LIMIT_PER_MIN=60

# Vite — API base (default /cms-api via proxy)
# VITE_CMS_API_BASE=/cms-api
