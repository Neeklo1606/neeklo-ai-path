# Copy into project root .env (do not commit secrets).

# Prisma (same Postgres as Supabase recommended)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres

# JWT for CMS API (min 32 characters in production)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# Primary admin (prisma seed upserts every run — change password in production)
# BOOTSTRAP_ADMIN_EMAIL=dsc-23@yandex.ru
# BOOTSTRAP_ADMIN_PASSWORD=your-secure-password
# BOOTSTRAP_ADMIN_NAME=Display Name

# CMS Node server
CMS_SERVER_PORT=8787

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Optional: OpenAI if assistants have no provider_api_key in DB
OPENAI_API_KEY=

# Vite — API base (default /cms-api via proxy)
# VITE_CMS_API_BASE=/cms-api
