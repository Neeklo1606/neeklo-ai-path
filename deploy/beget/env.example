# Скопируйте в .env в корне проекта на сервере (там же, где package.json и server/).

# PostgreSQL (Supabase → Settings → Database → URI, режим «Session» или прямой, порт 5432)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Supabase
SUPABASE_URL="https://xxxx.supabase.co"
SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# JWT: минимум 32 символа в продакшене
JWT_SECRET="замените_на_случайную_строку_не_короче_32_символов"

# Порт API (BeGet: тот же, что в .htaccess и pm2)
PORT=8787
# Альтернативное имя (если привычнее)
# CMS_SERVER_PORT=8787

# Опционально: ключ OpenAI, если у ассистентов в БД нет своего provider key
# OPENAI_API_KEY=

# Prisma seed (опционально переопределить дефолтного админа)
# BOOTSTRAP_ADMIN_EMAIL=dsc-23@yandex.ru
# BOOTSTRAP_ADMIN_PASSWORD=...
# BOOTSTRAP_ADMIN_NAME=Джон Уик
